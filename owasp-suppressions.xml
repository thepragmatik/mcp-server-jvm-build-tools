<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!--
        OWASP dependency-check suppression file (issue #78).

        Add an entry here ONLY for a finding that has been investigated and is a
        confirmed false positive or an accepted, documented risk. Every
        suppression MUST carry a justification and, where possible, an `until`
        expiry date so it is revisited. An empty file (no suppressions) means the
        scan blocks the build on any dependency with a CVSS >= 7 vulnerability.
        See docs/DEPENDENCY_MANAGEMENT.md.

        Example (commented out; copy + fill in when a real suppression is needed):

        <suppress until="2026-12-31Z">
            <notes>False positive: CVE applies to the server module, not the
            client artifact we depend on. Tracked in #NNN.</notes>
            <packageUrl regex="true">^pkg:maven/com\.example/some-lib@.*$</packageUrl>
            <cve>CVE-0000-00000</cve>
        </suppress>
    -->
</suppressions>
