      {
        "name": "audit_tool_access",
        "description": "Read the most recent tool invocation audit log entries. Returns timestamp, tool name, caller identity, authorization status, and duration. Satisfies OWASP MCP06 logging requirements.",
        "inputSchema": {
          "type": "object",
          "properties": {
