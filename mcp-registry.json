{
  "$schema": "https://spec.modelcontextprotocol.io/schemas/registry-v1.json",
  "name": "mcp-server-jvm-build-tools",
  "version": "0.1.1-SNAPSHOT",
  "description": "Unified MCP server for JVM build tools \u2014 Maven, Gradle, and SBT. Execute builds, detect project types, check dependency versions, analyze build output, validate configurations, scan credentials, detect dependency conflicts, profile build performance, check Java version compatibility, authorize tool access, manage async builds, detect flaky tests, audit supply chains, and generate SBOMs \u2014 all through a single MCP API.",
  "vendor": {
    "name": "The Pragmatik",
    "url": "https://github.com/thepragmatik"
  },
  "homepage": "https://github.com/thepragmatik/mcp-server-jvm-build-tools",
  "license": "Apache-2.0",
  "tags": [
    "maven",
    "gradle",
    "sbt",
    "build-tools",
    "java",
    "jvm",
    "devops",
    "development",
    "security",
    "supply-chain"
  ],
  "capabilities": {
    "tools": true,
    "resources": true,
    "prompts": true,
    "logging": false,
    "streamableHttp": true,
    "stdio": true
  },
  "transports": [
    {
      "type": "stdio",
      "description": "JSON-RPC via stdin/stdout. Compatible with Claude Desktop, Cursor, Cline, Goose, Continue, Windsurf."
    },
    {
      "type": "streamable-http",
      "description": "HTTP with SSE, CORS, health endpoints. Enable via --spring.profiles.active=http.",
      "endpoints": {
        "mcp": "/mcp/message",
        "serverCard": "/.well-known/mcp-server",
        "health": "/health",
        "readiness": "/health/ready",
        "liveness": "/health/live",
        "buildEvents": "/mcp/build-events/stream"
      }
    }
  ],
  "mcpVersions": [
    "2024-11-05",
    "2025-03-26"
  ],
